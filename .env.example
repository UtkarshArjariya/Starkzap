# ──────────────────────────────────────────────────────────────────
# Dare Board — Environment Variables
# Copy to .env and fill in the values
# ──────────────────────────────────────────────────────────────────

# ─ Frontend (React CRA) ────────────────────────────────────────────
# Set after deploying the Cairo contract (see contracts/scripts/deploy.ts)
REACT_APP_CONTRACT_ADDRESS=

# Starknet network: sepolia | mainnet
REACT_APP_STARKNET_NETWORK=sepolia

# Public RPC endpoint for Starknet Sepolia
REACT_APP_RPC_URL=https://starknet-sepolia.public.blastapi.io

# Privy App ID for Starkzap passkey/social login
# Get yours at: https://privy.io → Create App
REACT_APP_PRIVY_APP_ID=placeholder-privy-app-id

# ─ Backend (deployer wallet — server-side only, never expose to browser) ──
DEPLOYER_PUBLIC_KEY=0x05621F5e671ccb298FD6B226A8e0Bfba97DAF4BAa6196C2F12cEEe03A15765a9
DEPLOYER_PRIVATE_KEY=0x00dcd338a391374e143d3da83397431ae5ab6949fb055ca98735debde67fe742

# ─ Keep these as-is (Emergent platform) ────────────────────────────
# REACT_APP_BACKEND_URL=...
# WDS_SOCKET_PORT=443
# ENABLE_HEALTH_CHECK=false
